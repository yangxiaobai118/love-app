.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.friends-list {
  padding: 20rpx;
}

.friend-item {
  background-color: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.friend-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 20rpx;
}

.friend-info {
  flex: 1;
}

.friend-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.friend-nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 20rpx;
}

.friend-gender {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx;
}

.friend-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.affection {
  display: flex;
  align-items: center;
}

.affection-label {
  font-size: 24rpx;
  color: #999;
}

.affection-value {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: 500;
  margin-left: 8rpx;
}

.info-status {
  display: flex;
  align-items: center;
}

.info-status-text {
  font-size: 24rpx;
  color: #999;
}

.info-public {
  color: #52c41a;
}

.friend-actions {
  margin-left: 20rpx;
}

.public-btn {
  background-color: #1890ff;
  color: white;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  min-width: 120rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.search-btn {
  background-color: #ff4d4f;
  color: white;
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}