.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f5f5;
}

.logo {
  margin-bottom: 60rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.login-form {
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wechat-login-btn {
  width: 100%;
  height: 80rpx;
  background-color: #07C160;
  color: white;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.divider {
  width: 100%;
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background-color: #e8e8e8;
}

.divider-text {
  padding: 0 20rpx;
  color: #999;
  font-size: 24rpx;
}

.register-link {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #ff4d4f;
}

.tips {
  position: absolute;
  bottom: 60rpx;
  font-size: 20rpx;
  color: #999;
  display: flex;
  align-items: center;
}

.agreement-link {
  color: #1890ff;
  margin: 0 8rpx;
}