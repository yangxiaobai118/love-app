<view class="container">
  <view class="logo">
    <text class="logo-text">相亲征婚交友</text>
  </view>
  
  <view class="login-form">
    <button class="wechat-login-btn" bindtap="wechatLogin">
      <image src="/images/wechat-icon.png" class="wechat-icon"></image>
      <text class="wechat-login-text">微信一键登录</text>
    </button>
    
    <view class="divider">
      <text class="divider-text">或</text>
    </view>
    
    <navigator url="/pages/register/register" class="register-link">
      <text>立即注册</text>
    </navigator>
  </view>
  
  <view class="tips">
    <text>登录即表示同意</text>
    <navigator url="/pages/agreement/agreement" class="agreement-link">
      <text>《用户协议》</text>
    </navigator>
    <text>和</text>
    <navigator url="/pages/privacy/privacy" class="agreement-link">
      <text>《隐私政策》</text>
    </navigator>
  </view>
</view>