.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background-color: white;
  border-bottom: 2rpx solid #e8e8e8;
  position: relative;
}

.chat-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 16rpx;
}

.chat-gender {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx;
}

.chat-content {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message-item {
  margin-bottom: 24rpx;
  display: flex;
}

.message-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: auto;
  max-width: 70%;
}

.message-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-right: auto;
  max-width: 70%;
}

.message-text {
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.4;
  word-break: break-word;
}

.message-right .message-text {
  background-color: #1890ff;
  color: white;
  border-bottom-right-radius: 4rpx;
}

.message-left .message-text {
  background-color: white;
  color: #333;
  border-bottom-left-radius: 4rpx;
}

.message-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.chat-input {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: white;
  border-top: 2rpx solid #e8e8e8;
}

.input {
  flex: 1;
  height: 60rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 30rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
  background-color: #fafafa;
}

.send-btn {
  background-color: #1890ff;
  color: white;
  border-radius: 30rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  height: 60rpx;
}

.affection-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  background-color: #fff3f3;
  border-top: 2rpx solid #ffccc7;
}

.affection-label {
  font-size: 24rpx;
  color: #999;
}

.affection-value {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: 500;
  margin-left: 8rpx;
}