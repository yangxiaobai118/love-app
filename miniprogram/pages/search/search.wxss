.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.search-form {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: #333;
}

.radio-group {
  display: flex;
  align-items: center;
}

.radio {
  margin-right: 8rpx;
}

.radio-label {
  margin-right: 30rpx;
  font-size: 28rpx;
  color: #333;
}

.age-range {
  display: flex;
  align-items: center;
}

.age-input {
  width: 120rpx;
  height: 60rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.age-separator {
  margin: 0 20rpx;
  font-size: 28rpx;
  color: #999;
}

.input {
  width: 100%;
  height: 60rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.search-btn {
  width: 100%;
  height: 80rpx;
  background-color: #ff4d4f;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
}

.search-results {
  background-color: white;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.user-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.user-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-right: 16rpx;
}

.user-gender {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx;
}

.user-detail {
  display: flex;
  align-items: center;
}

.user-age {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.user-location {
  font-size: 24rpx;
  color: #999;
}

.add-btn {
  background-color: #1890ff;
  color: white;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  min-width: 120rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}